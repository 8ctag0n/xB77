FROM --platform=linux/amd64 ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install base dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    pkg-config \
    libudev-dev \
    llvm \
    libclang-dev \
    protobuf-compiler \
    libssl-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Clean any existing Rust/Solana installs and install Rust fresh
RUN rm -rf /root/.rustup /root/.cargo /root/.local/share/solana \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && . "$HOME/.cargo/env" \
    && rustup default stable \
    && rustc --version

# Install Solana and verify
RUN sh -c "$(curl -sSfL https://release.anza.xyz/stable/install)" \
    && /root/.local/share/solana/install/active_release/bin/solana --version

# Set persistent PATH for Solana and Rust
ENV PATH="/root/.cargo/bin:/root/.local/share/solana/install/active_release/bin:${PATH}"

# Install nvm and Node.js
ENV NVM_DIR="/root/.nvm"
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && . "$NVM_DIR/nvm.sh" \
    && echo "node" > .nvmrc \
    && nvm install 22 \
    && nvm use 22 \
    && node --version

# Install zk-compression-cli (source nvm again for this RUN)
RUN . "$NVM_DIR/nvm.sh" \
    && npm install -g @lightprotocol/zk-compression-cli@alpha \
    && light --help  # Verify CLI works

# Set a working directory
WORKDIR /app

# Example entrypoint
CMD ["/bin/bash"]