{
  "name": "@xb77/sdk",
  "version": "2.1.0",
  "description": "xB77 Sovereign Commerce Layer — TypeScript SDK (WASM core)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "wasm/xb77_core.wasm",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "copy-wasm": "mkdir -p wasm && cp ../../zig-out/bin/xb77_core.wasm wasm/",
    "prepublishOnly": "bun run copy-wasm && bun run build",
    "test": "bun test"
  },
  "keywords": [
    "xb77",
    "solana",
    "sdk",
    "wasm",
    "sovereign-commerce"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@zerodev/ecdsa-validator": "^5.4.9",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.10",
    "tslib": "^2.8.1",
    "viem": "^2.51.2"
  }
}
