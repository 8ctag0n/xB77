# Cloudflare Workers Static Assets — exclude patterns (gitignore syntax).
# Files matching these are NOT uploaded to the edge. Keeps deploys lean
# and avoids the 25 MiB per-file ceiling.

# Remotion is the brand source-of-truth — design-time only, never served.
# Its node_modules contains a 60 MiB rspack native binding among other large
# binaries, none of which belongs at the edge.
remotion/

# Build script for esbuild — runs at design time, not at request time.
build.sh

# JSX sources — esbuild compiles them to assets/js/ at design time.
# Production only needs the compiled JS; the JSX sources are ~540 KB of
# dev-only noise that shouldn't ride to the edge.
assets/src/

# Editor / OS noise
.DS_Store
*.swp
*~

# Source maps are huge and we don't ship them
**/*.map
